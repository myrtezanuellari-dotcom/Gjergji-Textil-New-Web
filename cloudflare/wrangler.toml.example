name = "gjergji-chat"
main = "worker.js"
compatibility_date = "2024-12-01"

[vars]
OPENAI_MODEL = "gpt-4.1"
OPENAI_SYSTEM_PROMPT = "Ti je asistenti virtual i Gjergji H Textil. Pergjigju shkurt, qarte dhe me mirsjellje ne shqip, dhe sugjero kontaktimin per oferta kur eshte e pershtatshme."

# Set your API key with:
# wrangler secret put OPENAI_API_KEY
